{
  "name": "ts-playwright-personal-framework",
  "version": "1.0.0",
  "description": "Production-grade E2E test automation framework — TypeScript · Playwright · Cucumber BDD · CI/CD",
  "main": "index.js",
  "scripts": {
    "test":               "cross-env TEST_ENV=staging cucumber-js --config cucumber.config.js",
    "test:dev":           "cross-env TEST_ENV=dev cucumber-js --config cucumber.config.js",
    "test:smoke":         "cross-env TEST_ENV=staging TAGS=@smoke cucumber-js --config cucumber.config.js",
    "test:negative":      "cross-env TEST_ENV=staging TAGS=@negative cucumber-js --config cucumber.config.js",
    "test:security":      "cross-env TEST_ENV=staging TAGS=@security cucumber-js --config cucumber.config.js",
    "test:headed":        "cross-env HEADLESS=false TEST_ENV=staging cucumber-js --config cucumber.config.js",
    "test:visual:update": "cross-env UPDATE_SNAPSHOTS=1 TEST_ENV=staging cucumber-js --config cucumber.config.js"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^10.3.2",
    "@playwright/test": "^1.44.0",
    "@types/node": "^20.0.0",
    "cross-env": "^10.1.0",
    "playwright": "^1.44.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3"
  }
}
